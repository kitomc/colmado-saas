# ColmadoAI SaaS — Environment Variables
# Copia este archivo como .env y llena los valores

# ============ GROQ (LLM) ============
GROQ_API_KEY=tu_groq_api_key_aqui

# ============ WhatsApp (Meta Cloud API) ============
WHATSAPP_VERIFY_TOKEN=token_de_verificacion_whatsapp
# WHATSAPP_TOKEN y WHATSAPP_PHONE_ID se leen del colmado en BD

# ============ Telegram ============
TELEGRAM_BOT_TOKEN=token_del_bot_de_telegram

# ============ Convex ============
# Estas se configuran automáticamente en convex dev
# CONVEX_DEPLOYMENT=...
# CONVEX_DEPLOY_KEY=...